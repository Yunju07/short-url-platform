DB_URL=jdbc:mysql://db:3306/shorturl?serverTimezone=Asia/Seoul&allowPublicKeyRetrieval=true&useSSL=false
DB_USERNAME=root
DB_PASSWORD=root
KAFKA_BOOTSTRAP_SERVERS=shorturl-kafka-1:19093,shorturl-kafka-2:19094,shorturl-kafka-3:19095

# url-service -> ai-service
AI_ENABLED=true
AI_BASE_URL=http://ai-service:8000
# First request can be slow due to model load/download.
AI_TIMEOUT_SECONDS=10
AI_MAX_ATTEMPTS=3

# ai-service provider settings (ai-service -> ollama)
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=phi3:mini
